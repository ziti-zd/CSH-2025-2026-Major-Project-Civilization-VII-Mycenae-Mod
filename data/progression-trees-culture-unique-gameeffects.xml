<?xml version="1.0" encoding="utf-8"?>
<GameEffects xmlns="GameEffects">
	<!-- Tomb-Building -->
	<Modifier id="MOD_ZESTER_PALACE_GOLD"
			  collection="COLLECTION_OWNER"
			  effect="EFFECT_PLAYER_ADJUST_CONSTRUCTIBLE_YIELD">
		<Argument name="ConstructibleType">BUILDING_PALACE</Argument>
		<Argument name="YieldType">YIELD_GOLD</Argument>
		<Argument name="Amount">10</Argument>
		<String context="Description">LOC_MOD_ZESTER_PALACE_GOLD_DESCRIPTION</String>
	</Modifier>

	<!-- Cyclopean Masonry -->
	<Modifier id="MOD_ZESTER_FORTIFICATION_PRODUCTION_BUFF"
			  collection="COLLECTION_PLAYER_CITIES"
			  effect="EFFECT_CITY_ADJUST_CONSTRUCTIBLE_PRODUCTION">
		<Argument name="Apply">Rate</Argument>
		<Argument name="Percent">50</Argument>
		<Argument name="Tag">FORTIFICATION</Argument>
		<Argument name="Tooltip">LOC_CIVIC_ZESTER_CYCLOPEAN_MASONRY_NAME</Argument>
		<String context="Description">LOC_MOD_ZESTER_FORTIFICATION_PRODUCTION_BUFF_DESCRIPTION</String>
	</Modifier>
	
	<!-- Mediterranean Trade -->
	<!--	Range Buff -->
	<Modifier id="MOD_ZESTER_LAND_TRADE_ROUTE_RANGE_BUFF"
			  collection="COLLECTION_PLAYER_CITIES"
			  effect="EFFECT_CITY_ADJUST_TRADE_ROUTE_RANGE">
		<Argument name="DomainType">DOMAIN_LAND</Argument>
		<Argument name="Amount">10</Argument>
		<Argument name="Tooltip">LOC_CIVIC_ZESTER_MEDITERRANEAN_TRADE</Argument>
		<String context="Description">LOC_MOD_ZESTER_TRADE_ROUTE_RANGE_BUFF_DESCRIPTION</String>
	</Modifier>
	<Modifier id="MOD_ZESTER_NAVAL_TRADE_ROUTE_RANGE_BUFF"
			  collection="COLLECTION_PLAYER_CITIES"
			  effect="EFFECT_CITY_ADJUST_TRADE_ROUTE_RANGE">
		<Argument name="DomainType">DOMAIN_SEA</Argument>
		<Argument name="Amount">10</Argument>
		<Argument name="Tooltip">LOC_CIVIC_ZESTER_MEDITERRANEAN_TRADE</Argument>
	</Modifier>
	<!--	Gold per Trade Route -->
	<!-- Base the Gold per trade route off of Achaemenid Xerxes' Incense Censer. -->
	
	<!-- Mediterranean Trade Mastery -->
	<Modifier id="MOD_ZESTER_PALACE_LEDGER_RESOURCE_GOLD"
			  collection="COLLECTION_OWNER"
			  effect="EFFECT_UNIT_ADJUST_COMMAND_AWARD">
		<Argument name="DomainType">DOMAIN_SEA</Argument>
		<Argument name="YieldType">YIELD_GOLD</Argument>
		<Argument name="Amount" type="ScaleByGameSpeed">25</Argument>
		<Argument name="PerResource">true</Argument>
		<Argument name="CommandType">UNITCOMMAND_MAKE_TRADE_ROUTE</Argument>
		<String context="Description">LOC_MOD_ZESTER_GOLD_ON_RESOURCE_DESCRIPTION</String>
	</Modifier>
	
	<!-- Warrior Elite -->
	<!--	Commander Promition -->
	<Modifier id="MOD_ZESTER_COMMANDER_PROMOTIONS"
			  collection="COLLECTION_PLAYER_UNITS"
			  effect="EFFECT_GRANT_UNIT_PROMOTION">
		<SubjectRequirements>
			<Requirement type="REQUIREMENT_UNIT_TAG_MATCHES">
				<Argument name="Tag">UNIT_CLASS_ARMY_COMMANDER</Argument>
			</Requirement>
		</SubjectRequirements>
		<Argument name="UnitPromotionType">PROMOTION_ARMY_LOOTING</Argument>
		<Argument name="UnitPromotionDisciplineType">DISCIPLINE_ARMY_LOGISTICS</Argument>
		<String context="Description">LOC_MOD_ZESTER_COMMANDER_PROMOTIONS_DESCRIPTION</String>
	</Modifier>
	
	<!--	Palace Ledger on Settlement Capture -->
	<Modifier id="MOD_ZESTER_LEDGER_ON_CAPTURE"
			  collection="COLLECTION_PLAYER_CITIES"
			  effect="EFFECT_CITY_GRANT_UNIT">
		<SubjectRequirements>
			<Requirement type="REQUIREMENT_PLAYER_FIRST_TIME_SETTLEMENT_OCCUPATION">
				<Argument name="OwnerSettled">false</Argument>
			</Requirement>
		</SubjectRequirements>
		<Argument name="UnitTag">UNIT_CLASS_MERCHANT</Argument>
		<Argument name="AllowUniqueOverride">true</Argument>
		<String context="Description">LOC_MOD_ZESTER_LEDGER_ON_CAPTURE_DESCRIPTION</String>
	</Modifier>
</GameEffects>